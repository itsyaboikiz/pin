local Lighting = game:GetService("Lighting")

local plr = Players.LocalPlayer

--// SAFE NAMECALL HOOK
local mt = getrawmetatable(game)
setreadonly(mt, false)
local oldNamecall = mt.__namecall

mt.__namecall = newcclosure(function(self, ...)
    local method = getnamecallmethod()
    if method == "FireServer" or method == "InvokeServer" then
        -- don't break the game, just pass through safely
        return oldNamecall(self, ...)
    end
    return oldNamecall(self, ...)
end)

setreadonly(mt, true)

--// SAFE LOG BLOCK
pcall(function()
    if getconnections then
        for _, v in pairs(getconnections(game:GetService("LogService").MessageOut)) do
            pcall(function() v:Disable() end)
        end
    end
end)

--// CHARACTER HANDLING
local character, humanoid, rootPart, head

local function updateCharacter(char)
    character = char
    humanoid = char:WaitForChild("Humanoid")
    rootPart = char:WaitForChild("HumanoidRootPart")
    head = char:WaitForChild("Head")
end

updateCharacter(plr.Character or plr.CharacterAdded:Wait())

plr.CharacterAdded:Connect(function(char)
    updateCharacter(char)
end)

--// VARIABLES (UNCHANGED)
local smoothPullEnabled = false
local isSmoothPulling = false
local magnetSmoothness = 0.08
local maxPullDistance = 35

local boostEnabled = false
local boostPower = 25
local boostCooldown = {}

local simpleBoostEnabled = false
local simpleBoostPower = 25
local simpleBoostCooldown = {}

local jumpPowerEnabled = false
local customJumpPower = 50
local jumpConnection = nil

--// SAFE FOOTBALL FINDER (unchanged logic, just nil safe)
local function getFootball()
    for _, v in pairs(Workspace:GetDescendants()) do
        if v:IsA("BasePart") and v.Name == "Football" then
            return v
        end
    end
    return nil
end

--// HAS BALL
local function hasFootball()
    local ball = getFootball()
    if not ball or not rootPart then return false end
    return (ball.Position - rootPart.Position).Magnitude < 5
end

--// BOOST
local function boostPlayer(power)
    if not rootPart then return end
    
    local bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(0, math.huge, 0)
    bv.Velocity = Vector3.new(0, power, 0)
    bv.Parent = rootPart

    task.delay(0.2, function()
        if bv then bv:Destroy() end
    end)
end

local function setupBoost()
    rootPart.Touched:Connect(function(hit)
        if not hit or not hit.Parent then return end
        
        local otherPlayer = Players:GetPlayerFromCharacter(hit.Parent)
        if not otherPlayer or otherPlayer == plr then return end

        if boostEnabled and hasFootball() then
            if not boostCooldown[otherPlayer] or tick() - boostCooldown[otherPlayer] > 1 then
                boostCooldown[otherPlayer] = tick()
                boostPlayer(boostPower)
            end
        end

        if simpleBoostEnabled then
            if not simpleBoostCooldown[otherPlayer] or tick() - simpleBoostCooldown[otherPlayer] > 1 then
                simpleBoostCooldown[otherPlayer] = tick()
                boostPlayer(simpleBoostPower)
            end
        end
    end)
end

setupBoost()

--// SMOOTH PULL
local function smoothTeleportToBall()
    local ball = getFootball()
    if not ball or not rootPart then return end

    local distance = (ball.Position - rootPart.Position).Magnitude
    if distance > maxPullDistance then return end

    rootPart.CFrame = rootPart.CFrame:Lerp(
        CFrame.new(ball.Position + Vector3.new(0, 3, 0)),
        magnetSmoothness
    )
end

UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        if smoothPullEnabled then
            isSmoothPulling = true
            task.spawn(function()
                while isSmoothPulling do
                    smoothTeleportToBall()
                    task.wait()
                end
            end)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        isSmoothPulling = false
    end
end)

--// FIXED JUMP POWER (IMPORTANT FIX)
local function setupJump()
    if jumpConnection then
        jumpConnection:Disconnect()
    end

    jumpConnection = humanoid.Jumping:Connect(function()
        if jumpPowerEnabled and rootPart then
            local vel = rootPart.AssemblyLinearVelocity
            rootPart.AssemblyLinearVelocity = Vector3.new(vel.X, customJumpPower, vel.Z)
        end
    end)
end

setupJump()

